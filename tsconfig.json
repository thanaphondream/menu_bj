{
  "compilerOptions": {
    "target": "ES6",
    "module": "commonjs",
    "rootDir": "./src",        
    "outDir": "./dist",       
    "strict": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,
     "typeRoots": [
      "./src/@types",
      "./node_modules/@types"
    ]
  },
  "include": ["src/**/*"],    
  "exclude": ["node_modules"]
}
